## Ignore Visual Studio temporary files, build results, and
## files generated by popular Visual Studio add-ons.

# User-specific files
*.suo
*.user
*.userosscache
*.sln.docstates

# Build results
[Dd]ebug/
[Dd]ebugPublic/
[Rr]elease/
[Rr]eleases/
x64/
x86/
[Bb]in/
[Oo]bj/
[Pp]ublish/

# .NET
project.lock.json
project.fragment.lock.json
artifacts/

# Visual Studio Code
.vscode/

# JetBrains Rider
.idea/

# MacOS
.DS_Store

# NuGet
*.nupkg
**/packages/*
!**/packages/build/

# Tools downloaded at runtime by Music Downloader (yt-dlp.exe, ffmpeg.exe)
tools/
