<Window
  xmlns="https://github.com/avaloniaui"
  xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
  xmlns:vm="clr-namespace:MusicDownloader.ViewModels"
  xmlns:svc="clr-namespace:MusicDownloader.Services"
  x:Class="MusicDownloader.Views.MainWindow"
  x:DataType="vm:MainViewModel"
  Title="Music Downloader"
  Width="900"
  Height="720"
  MinWidth="680"
  MinHeight="560"
  WindowStartupLocation="CenterScreen"
  Background="White"
>
  <Window.Resources>
    <svc:AudioFormatLabelConverter x:Key="AudioFormatLabelConverter" />
    <svc:NotConverter x:Key="NotConverter" />
    <svc:CountToEmptyConverter x:Key="CountToEmptyConverter" />
    <svc:BusyLabelConverter x:Key="BusyLabelConverter" />

    <SolidColorBrush x:Key="AccentBrush" Color="#2563EB" />
    <SolidColorBrush x:Key="MutedBrush" Color="#6B7280" />
    <SolidColorBrush x:Key="BorderBrush" Color="#E5E7EB" />
    <SolidColorBrush x:Key="WarnBrush" Color="#B45309" />
    <SolidColorBrush x:Key="WarnBgBrush" Color="#FEF3C7" />
    <SolidColorBrush x:Key="ConsoleBgBrush" Color="#0F172A" />
    <SolidColorBrush x:Key="ConsoleFgBrush" Color="#E2E8F0" />
  </Window.Resources>

  <Window.Styles>
    <Style Selector="TextBlock.label">
      <Setter Property="FontWeight" Value="SemiBold" />
      <Setter Property="Margin" Value="0,0,0,4" />
    </Style>
    <Style Selector="Button.action">
      <Setter Property="MinWidth" Value="140" />
      <Setter Property="Height" Value="40" />
      <Setter Property="Padding" Value="20,0" />
      <Setter Property="FontWeight" Value="SemiBold" />
      <Setter Property="CornerRadius" Value="6" />
      <Setter Property="HorizontalContentAlignment" Value="Center" />
      <Setter Property="VerticalContentAlignment" Value="Center" />
    </Style>
    <Style Selector="Button.primary">
      <Setter Property="Background" Value="{StaticResource AccentBrush}" />
      <Setter Property="Foreground" Value="White" />
    </Style>
    <Style Selector="Button.primary:pointerover /template/ ContentPresenter">
      <Setter Property="Background" Value="#1D4ED8" />
    </Style>
    <Style Selector="TextBox">
      <Setter Property="Padding" Value="8,6" />
      <Setter Property="MinHeight" Value="34" />
    </Style>
    <Style Selector="ComboBox">
      <Setter Property="Padding" Value="8,6" />
      <Setter Property="MinHeight" Value="34" />
    </Style>
  </Window.Styles>

  <Grid Margin="24" RowDefinitions="Auto,Auto,Auto,Auto,Auto,*,Auto">
    <StackPanel Grid.Row="0" Margin="0,0,0,18">
      <TextBlock Text="Music Downloader by CALL FRASER" FontSize="26" FontWeight="SemiBold" />
      <TextBlock
        Text="Wklej link i kliknij Pobierz."
        Foreground="{StaticResource MutedBrush}"
        FontSize="13"
        Margin="0,4,0,0"
      />
    </StackPanel>

    <StackPanel Grid.Row="1" Margin="0,0,0,14">
      <TextBlock Classes="label" Text="Link" />
      <TextBox
        Text="{Binding PlaylistUrl, Mode=TwoWay}"
        IsEnabled="{Binding IsBusy, Converter={StaticResource NotConverter}}"
        Watermark="YouTube / SoundCloud / Spotify (link do utworu, albumu lub playlisty)"
      />
    </StackPanel>

    <Grid Grid.Row="2" Margin="0,0,0,16" ColumnDefinitions="*,12,280">
      <StackPanel Grid.Column="0">
        <TextBlock Classes="label" Text="Zapisz do" />
        <Grid ColumnDefinitions="*,8,Auto,8,Auto">
          <TextBox
            Grid.Column="0"
            Text="{Binding OutputDirectory, Mode=TwoWay}"
            IsEnabled="{Binding IsBusy, Converter={StaticResource NotConverter}}"
          />
          <Button
            Grid.Column="2"
            Content="Przeglądaj..."
            Command="{Binding BrowseOutputDirectoryCommand}"
            IsEnabled="{Binding IsBusy, Converter={StaticResource NotConverter}}"
          />
          <Button Grid.Column="4" Content="Otwórz" Command="{Binding OpenOutputDirectoryCommand}" />
        </Grid>
      </StackPanel>

      <StackPanel Grid.Column="2">
        <TextBlock Classes="label" Text="Format" />
        <ComboBox
          ItemsSource="{Binding Formats}"
          SelectedItem="{Binding Format}"
          HorizontalAlignment="Stretch"
          IsEnabled="{Binding IsBusy, Converter={StaticResource NotConverter}}"
        >
          <ComboBox.ItemTemplate>
            <DataTemplate>
              <TextBlock Text="{Binding Converter={StaticResource AudioFormatLabelConverter}}" />
            </DataTemplate>
          </ComboBox.ItemTemplate>
        </ComboBox>
      </StackPanel>
    </Grid>

    <Border
      Grid.Row="3"
      Margin="0,0,0,12"
      Padding="12,8"
      CornerRadius="6"
      Background="{StaticResource WarnBgBrush}"
      BorderBrush="{StaticResource WarnBrush}"
      BorderThickness="1"
      IsVisible="{Binding IsLosslessFormatSelected}"
    >
      <TextBlock
        Foreground="{StaticResource WarnBrush}"
        TextWrapping="Wrap"
        Text="⚠ Wybrałeś format bezstratny (WAV / FLAC / AIFF). Można go użyć, ale źródło z YouTube / SoundCloud jest stratne — jakość dźwięku NIE będzie lepsza, a plik będzie kilka razy większy."
      />
    </Border>

    <StackPanel Grid.Row="4" Orientation="Horizontal" Margin="0,0,0,16" Spacing="10">
      <Button
        Classes="action primary"
        Content="{Binding IsBusy, Converter={StaticResource BusyLabelConverter}}"
        Command="{Binding DownloadCommand}"
      />
      <Button Classes="action" Content="Anuluj" Command="{Binding CancelCommand}" />
      <ProgressBar
        IsIndeterminate="True"
        IsVisible="{Binding IsBusy}"
        VerticalAlignment="Center"
        Width="220"
        Height="6"
        Foreground="{StaticResource AccentBrush}"
      />
    </StackPanel>

    <Border
      Grid.Row="5"
      BorderBrush="{StaticResource BorderBrush}"
      BorderThickness="1"
      CornerRadius="6"
      Background="{StaticResource ConsoleBgBrush}"
      ClipToBounds="True"
    >
      <Panel>
        <TextBlock
          Text="Tu pojawi się postęp pobierania."
          HorizontalAlignment="Center"
          VerticalAlignment="Center"
          Foreground="{StaticResource MutedBrush}"
          IsVisible="{Binding LogLines.Count, Converter={StaticResource CountToEmptyConverter}}"
        />
        <ScrollViewer
          x:Name="LogScroller"
          HorizontalScrollBarVisibility="Auto"
          VerticalScrollBarVisibility="Auto"
          Padding="14,10"
        >
          <ItemsControl ItemsSource="{Binding LogLines}">
            <ItemsControl.ItemTemplate>
              <DataTemplate>
                <TextBlock
                  Text="{Binding}"
                  FontFamily="Menlo, Consolas, Courier New, monospace"
                  FontSize="12"
                  Foreground="{StaticResource ConsoleFgBrush}"
                  TextWrapping="NoWrap"
                />
              </DataTemplate>
            </ItemsControl.ItemTemplate>
          </ItemsControl>
        </ScrollViewer>
      </Panel>
    </Border>

    <TextBlock
      Grid.Row="6"
      Margin="0,14,0,0"
      Text="{Binding StatusText}"
      Foreground="{StaticResource MutedBrush}"
    />
  </Grid>
</Window>
